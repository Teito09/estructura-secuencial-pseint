Algoritmo Modulacion
	Definir a,b,divisor, moduloa, modulob Como Real
	Escribir  "Ingrese el valor del divisor"
	Leer divisor
	Escribir "Ingrese el valor de a"
	Leer a
	Escribir "Ingrese el valor de b"
	Leer b
	moduloa = a%divisor
	Escribir "El modulo de a es " moduloa
	modulob = b%divisor
	Escribir "El modulo de b es " modulob
FinAlgoritmo
