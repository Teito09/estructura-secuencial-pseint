Algoritmo Rectangulo
	Definir base, altura, perimetro Como Real
	Escribir "Introduce el valor de la base "
	Leer base
	Escribir "Introducir el valor de la altura "
	Leer altura
	area = base*altura
	perimetro = 2*(base+altura) 
	Escribir "El ·rea del rect·ngulo es " area
    Escribir "El perÌmetro del rect·ngulo es " perimetro
FinAlgoritmo
