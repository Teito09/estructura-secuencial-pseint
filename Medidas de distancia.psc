Algoritmo Medidas
	Definir centimetros,yardas,metros,pulgadas,pies Como Real
	Escribir "Ingrese el valor de centimetros"
	Leer centimetros 
	metros = centimetros/100
	Escribir "En metros seria " metros " metros"
	yardas = centimetros*0.010936
	Escribir "En yardas seria " yardas " yardas"
	pies = centimetros*0.032808
	Escribir "En pies seria " pies " pies"
	pulgadas = centimetros*0.3937
	Escribir "En pulgadas seria " pulgadas " pulgadas"
FinAlgoritmo
